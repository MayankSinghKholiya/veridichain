# QIE Testnet RPC
QIE_RPC_URL=https://rpc1testnet.qie.digital/

# Your deployer wallet private key (NO 0x prefix needed for some setups)
# Get testnet QIE from: https://www.qie.digital/faucet
PRIVATE_KEY=your_private_key_here

# QIE Explorer API key for contract verification
QIE_EXPLORER_API_KEY=your_explorer_api_key

# QIE ecosystem contract addresses (fill after you research QIE Pass + Stable Coin addresses)
QIE_PASS_CONTRACT=0x0000000000000000000000000000000000000000
QIE_STABLE_COIN_CONTRACT=0x0000000000000000000000000000000000000000
QIE_DEX_CONTRACT=0x0000000000000000000000000000000000000000

# Institution staking amount (in QIEUSD, 18 decimals)
STAKE_AMOUNT=100000000000000000000
