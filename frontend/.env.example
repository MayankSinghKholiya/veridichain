# ─────────────────────────────────────────────────────────────
#  VeridiChain — Frontend Environment Variables
#  Copy this file to .env.local and fill in the values.
#  Never commit .env.local — it contains real secrets.
# ─────────────────────────────────────────────────────────────

# QIE Mainnet
NEXT_PUBLIC_QIE_RPC_URL=https://rpc1mainnet.qie.digital/
NEXT_PUBLIC_QIE_CHAIN_ID=1990
NEXT_PUBLIC_QIE_EXPLORER_URL=https://mainnet.qie.digital

# Deployed contract addresses (QIE Mainnet)
NEXT_PUBLIC_INSTITUTION_REGISTRY=0x936129F672B2754c25e569a5BEC7b689BaD174c1
NEXT_PUBLIC_CREDENTIAL_REGISTRY=REPLACE_ME
NEXT_PUBLIC_CREDENTIAL_NFT=REPLACE_ME
NEXT_PUBLIC_MANUAL_VERIFICATION_REGISTRY=REPLACE_ME

# QIE Ecosystem token/contract addresses
NEXT_PUBLIC_QIE_PASS_ADDRESS=REPLACE_ME
NEXT_PUBLIC_QIE_STABLE_COIN_ADDRESS=REPLACE_ME
NEXT_PUBLIC_QIE_DEX_ADDRESS=REPLACE_ME

# QIE Pass API — server-side only (never expose to browser)
# Apply for partner access at: https://pass-api.qie.digital
QIEPASS_BASE_URL=https://pass-api.qie.digital
QIEPASS_PUBLIC_KEY=pk_live_REPLACE_ME
QIEPASS_SECRET_KEY=sk_live_REPLACE_ME

# Pinata IPFS — server-side only
# Get your JWT from: https://app.pinata.cloud → API Keys → New Key (Admin)
PINATA_JWT=REPLACE_ME

# Credential metadata encryption key — server-side only
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be exactly 64 hex chars (32 bytes for AES-256-GCM)
METADATA_ENC_KEY=REPLACE_ME_WITH_64_HEX_CHARS

# Admin wallet addresses (comma-separated) — gets access to /admin
NEXT_PUBLIC_ADMIN_WALLETS=0xYOUR_WALLET_ADDRESS

# Misc
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_PINATA_GATEWAY=https://gateway.pinata.cloud/ipfs/
NEXT_PUBLIC_QIEPASS_PUBLIC_KEY=pk_live_REPLACE_ME
