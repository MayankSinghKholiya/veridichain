# ─────────────────────────────────────────────────────────────
#  VeridiChain — Frontend Environment Variables
#  Copy this file to .env.local and fill in the values.
#  Never commit .env.local — it contains real secrets.
# ─────────────────────────────────────────────────────────────

# ── QIE Chain (no changes needed for testnet) ─────────────────
NEXT_PUBLIC_QIE_RPC_URL=https://rpc1testnet.qie.digital/
NEXT_PUBLIC_QIE_CHAIN_ID=1983
NEXT_PUBLIC_QIE_EXPLORER_URL=https://testnet.qie.digital

# ── Deployed Contract Addresses ───────────────────────────────
# Use the addresses below (already deployed on QIE Testnet)
# or deploy your own: cd contracts && npx hardhat run scripts/deploy.js --network qie_testnet
NEXT_PUBLIC_INSTITUTION_REGISTRY=0xd20B0b3b663239f4A2Ce05C7d0a9dD734098f90F
NEXT_PUBLIC_CREDENTIAL_REGISTRY=0x4F446C17F438BF545C6991e0b3BBF27Af5Ad35C0
NEXT_PUBLIC_CREDENTIAL_NFT=0x01ee46CD8B14a58690b971CC5B6DC0EE353d4D28
NEXT_PUBLIC_MANUAL_VERIFICATION_REGISTRY=0x006FfB80584F718119021a0477359d4334bB8fD0

# ── QIE Ecosystem (testnet — leave as zero) ───────────────────
NEXT_PUBLIC_QIE_PASS_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_QIE_STABLE_COIN_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_QIE_DEX_ADDRESS=0x0000000000000000000000000000000000000000

# ── QIE Pass API — SERVER-SIDE ONLY ──────────────────────────
# Apply for partner access at: https://pass-api.qie.digital
# These keys are NEVER exposed to the browser (no NEXT_PUBLIC_ prefix)
QIEPASS_BASE_URL=https://pass-api.qie.digital
QIEPASS_PUBLIC_KEY=pk_live_REPLACE_ME
QIEPASS_SECRET_KEY=sk_live_REPLACE_ME

# ── Pinata IPFS — SERVER-SIDE ONLY ───────────────────────────
# Sign up free at: https://app.pinata.cloud
# Create an API key with Admin scope
PINATA_JWT=REPLACE_ME

# ── Credential Metadata Encryption — SERVER-SIDE ONLY ────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be exactly 64 hex characters (32 bytes for AES-256-GCM)
METADATA_ENC_KEY=REPLACE_ME_WITH_64_HEX_CHARS

# ── Admin Wallet Whitelist ─────────────────────────────────────
# Comma-separated wallet addresses that get full /admin access
# Example: 0xABC123...,0xDEF456...
NEXT_PUBLIC_ADMIN_WALLETS=0xYOUR_WALLET_ADDRESS

# ── Misc ───────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_PINATA_GATEWAY=https://gateway.pinata.cloud/ipfs/
NEXT_PUBLIC_QIEPASS_PUBLIC_KEY=pk_live_REPLACE_ME
