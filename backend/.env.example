# Server
PORT=3001
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:password@localhost:5432/veridichain?schema=public"

# JWT
JWT_SECRET=change_this_to_a_long_random_string_minimum_32_chars
JWT_EXPIRES_IN=7d

# Email OTP (Resend)
RESEND_API_KEY=re_your_resend_api_key
FROM_EMAIL=noreply@veridichain.io

# Pinata IPFS
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET_KEY=your_pinata_secret_key
PINATA_GATEWAY=https://gateway.pinata.cloud/ipfs/

# Encryption key for credential data (32 chars)
ENCRYPTION_KEY=change_this_32_char_encryption_key

# QIE Chain (for backend event listening)
QIE_RPC_URL=https://rpc1testnet.qie.digital/
INSTITUTION_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
CREDENTIAL_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
